#!/usr/bin/env bash
hostPrettyName=$(hostnamectl -j | jq -r .OperatingSystemPrettyName)
case ${hostPrettyName} in
"Arch Linux")
  sudo reflector --country US --latest 5 --sort rate --save /etc/pacman.d/mirrorlist
  yay -Syu
  ;;
"CachyOS")
  cachy-update
  ;;
"Garuda Linux")
  update
  ;;
*)
  printf "Unsupported host %s\n" ${hostPrettyName}
  ;;
esac
